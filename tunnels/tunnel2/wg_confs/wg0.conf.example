# DarkWatch — WireGuard config template (Tor egress path)
# Replace with a real config from your VPN provider.
# Real configs live at /var/lib/darkwebapp/secrets/proton_wg/wg_confs/wg0.conf and never enter the repo.

[Interface]
PrivateKey = <YOUR_WG_PRIVATE_KEY>
Address    = 10.2.0.2/32
DNS        = 10.2.0.1

[Peer]
PublicKey         = <PROVIDER_PUBLIC_KEY>
AllowedIPs        = 0.0.0.0/0, ::/0
Endpoint          = <PROVIDER_ENDPOINT_IP>:51820
PersistentKeepalive = 25
