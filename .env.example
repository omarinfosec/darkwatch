# =============================================================================
# DarkWatch — environment template
#
# Real values live ONLY at /var/lib/darkwebapp/env on the VM.
#   sudo install -d -m 0700 -o root -g root /var/lib/darkwebapp
#   sudo cp .env.example /var/lib/darkwebapp/env
#   sudo chmod 600 /var/lib/darkwebapp/env
#   sudo $EDITOR /var/lib/darkwebapp/env
#
# Compose reads /var/lib/darkwebapp/env via `env_file:` AND for variable
# substitution in port mappings (via the .env symlink at the project root).
# Never commit a populated copy of this file.
# =============================================================================

# ── Telegram (Telethon client) ──────────────────────────────────────────────
# Get from https://my.telegram.org/apps. The session file is created on first
# login and persists at $TELEGRAM_SESSION_PATH; back it up if you don't want
# to re-authenticate.
#
# Can also be set via the Setup UI (docker compose --profile setup up -d setup).
# Leave blank at first install — deploy does not require these; Telegram scraping
# stays disabled until you add them through the UI or edit this file.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION_PATH=/app/data/telegram.session

# ── Tor control (read by darkwatch for NEWNYM circuit rotation) ─────────────
# Generate once: openssl rand -hex 32
TOR_CONTROL_PASSWORD=

# ── Alerting (optional — leave blank to disable) ────────────────────────────
TELEGRAM_ALERT_BOT_TOKEN=
TELEGRAM_ALERT_CHAT_ID=
SLACK_WEBHOOK_URL=

# ── Setup UI auth ───────────────────────────────────────────────────────────
# Bearer token gating the Setup UI. The container listens internally on 8090
# and is published on the host as port 8082 by default (override with
# SETUP_HOST_PORT below). Generated by ops/bootstrap.sh on first run and
# printed to stdout once. Rotate via:
#   sudo openssl rand -hex 32 > /tmp/t && \
#   sudo sed -i "s/^SETUP_AUTH_TOKEN=.*/SETUP_AUTH_TOKEN=$(cat /tmp/t)/" \
#         /var/lib/darkwebapp/env && rm /tmp/t
SETUP_AUTH_TOKEN=

# Host port the Setup UI is published on. Default 8082 — some networks block
# 8090 while leaving 8082 through. Leave commented to take the default.
# SETUP_HOST_PORT=8082

# ── Ops ─────────────────────────────────────────────────────────────────────
# Used by ops/deploy.sh and the compose volumes. Pre-deploy refuses to start
# if these point at non-existent paths.
DARKWEBAPP_DATA_ROOT=/var/lib/darkwebapp

# Host paths for the Setup UI when it runs `docker compose` via the Docker
# socket. ops/bootstrap.sh writes these from the actual checkout location —
# do not edit unless you moved the repo or data directory.
# DARKWATCH_HOST_REPO_ROOT=/opt/darkwebapp
# DARKWATCH_HOST_DATA_ROOT=/var/lib/darkwebapp

# Bind dashboards to a specific interface IP. By default 127.0.0.1 — operator
# reaches the dashboards via SSH tunnel (`ssh -L 8080:localhost:8080 vm`) or
# their own VPN. Set to a WireGuard internal IP or the host's private IP if
# you want direct access from your operator network.
# Do NOT set to 0.0.0.0 unless you've put auth in front (the dashboards
# themselves have none).
DARKWATCH_BIND_IP=127.0.0.1
